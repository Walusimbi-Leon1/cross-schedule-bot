# ─── Firebase ───
# Service account JSON (from Firebase Console → Project Settings → Service Accounts → Generate)
# Paste the entire JSON as a single line, or store in a file and use FIREBASE_SERVICE_ACCOUNT_PATH
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_DATABASE_URL=https://oddsalley-31ydy-default-rtdb.firebaseio.com

# ─── Mastodon ───
MASTODON_TOKEN=
MASTODON_INSTANCE=https://mastodon.social

# ─── Bluesky ───
BLUESKY_USERNAME=
BLUESKY_PASSWORD=

# ─── Telegram ───
# Get bot token from https://t.me/BotFather
# Channel: your channel @username or numeric ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ─── Runtime (optional) ───
DRY_RUN=false
